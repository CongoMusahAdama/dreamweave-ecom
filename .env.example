# Frontend — copy to harv/.env.local for local dev
# Country code + number, no + or spaces (e.g. Ghana: 233XXXXXXXXX)
VITE_WHATSAPP_NUMBER=233201274491

# Local dev only — leave unset on Render (combined deploy uses same origin)
VITE_API_URL=http://localhost:5000

# Render: set VITE_WHATSAPP_NUMBER in the web service env vars before build.
# Backend secrets live in harv/backend/.env.example

