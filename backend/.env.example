# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/harv

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d

# Cloudinary (product image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin (used by POST /api/admin/setup in development)
ADMIN_EMAIL=harv@admin.com
ADMIN_PASSWORD=harv12345

# CORS — set to your Render URL after deploy, e.g. https://harv.onrender.com
FRONTEND_URL=http://localhost:8080

# Paystack (optional — card checkout)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
