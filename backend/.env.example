# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/harv

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d

# Cloudinary (product image uploads)
# Copy exact Cloud name from console.cloudinary.com (e.g. dxxxx — NOT the display name "harv")
# Or paste the full CLOUDINARY_URL from the dashboard (recommended on Render)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin (used by POST /api/admin/setup in development)
ADMIN_EMAIL=harv@admin.com
ADMIN_PASSWORD=harv12345

# CORS — set to your Render URL after deploy, e.g. https://harv.onrender.com
FRONTEND_URL=http://localhost:8080

# Paystack — card checkout (GHS). Dashboard → Settings → API Keys & Webhooks
# Public key: pk_test_... or pk_live_...
# Secret key: sk_test_... or sk_live_...
# Webhook URL (production): https://YOUR-API.onrender.com/api/payments/webhook
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Brevo — transactional email & SMS (https://app.brevo.com)
# API key: SMTP & API → API keys
# Verify sender email in Brevo → Senders
# SMS: buy credits + set sender name (max 11 chars, e.g. HARVDREAMS)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=harvdreamsww@gmail.com
BREVO_SENDER_NAME=HARV DREAMS
BREVO_SMS_SENDER=HARV
# Where new-order alerts go (defaults to ADMIN_EMAIL)
ADMIN_NOTIFY_EMAIL=harvdreamsww@gmail.com
