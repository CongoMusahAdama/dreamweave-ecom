# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/harv

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE=7d

# Cloudinary (product image uploads)
# Copy exact Cloud name from console.cloudinary.com (e.g. dxxxx — NOT the display name "harv")
# Or paste the full CLOUDINARY_URL from the dashboard (recommended on Render)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin (POST /api/admin/setup — dev only unless ALLOW_ADMIN_SETUP=true)
ADMIN_EMAIL=harv@admin.com
ADMIN_PASSWORD=harv12345
ALLOW_ADMIN_SETUP=false

# CORS — local dev URL; Paystack callbacks use this in development
FRONTEND_URL=http://localhost:8080
# Customer SMS/email links — always use live site (optional; defaults to harvdreams.com when FRONTEND_URL is localhost)
PUBLIC_SITE_URL=https://harvdreams.com

# Paystack — card checkout (GHS). Dashboard → Settings → API Keys & Webhooks
# Public key: pk_test_... or pk_live_...
# Secret key: sk_test_... or sk_live_...
# Webhook URL (production): https://YOUR-API.onrender.com/api/payments/webhook
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Brevo — transactional email only (https://app.brevo.com)
# API key: SMTP & API → API keys
# Verify sender email in Brevo → Senders
BREVO_API_KEY=
BREVO_SENDER_EMAIL=harvdreamsww@gmail.com
BREVO_SENDER_NAME=HARV DREAMS

# Mnotify — transactional SMS (https://apps.mnotify.com)
# API key: Account → API → Generate key
# Sender ID must be registered and approved in Mnotify dashboard
MNOTIFY_API_KEY=
MNOTIFY_SENDER_ID=HARV DREAMS

# Admin alerts — email via Brevo, SMS via Mnotify
ADMIN_NOTIFY_EMAIL=harvdreamsww@gmail.com
ADMIN_NOTIFY_PHONE=0540000000
